{% extends 'admin/base.html.twig' %}

{% block page_title %}Dashboard{% endblock %}
{% block topbar_title %}Dashboard{% endblock %}

{% block content %}
    {# Stats cards — one row, 4 columns #}
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0" style="border-radius:.75rem;">
                <div class="card-body text-center py-4">
                    <div class="mb-2"><i class="bi bi-collection-fill fs-2 text-primary"></i></div>
                    <div class="display-6 fw-bold">{{ leagueCount }}</div>
                    <div class="text-muted mt-1" style="font-size:.8125rem;">Leagues</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0" style="border-radius:.75rem;">
                <div class="card-body text-center py-4">
                    <div class="mb-2"><i class="bi bi-people-fill fs-2 text-success"></i></div>
                    <div class="display-6 fw-bold">{{ teamCount }}</div>
                    <div class="text-muted mt-1" style="font-size:.8125rem;">Teams</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0" style="border-radius:.75rem;">
                <div class="card-body text-center py-4">
                    <div class="mb-2"><i class="bi bi-calendar2-event-fill fs-2 text-warning"></i></div>
                    <div class="display-6 fw-bold">{{ matchCount }}</div>
                    <div class="text-muted mt-1" style="font-size:.8125rem;">Matches</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0" style="border-radius:.75rem;">
                <div class="card-body text-center py-4">
                    <div class="mb-2"><i class="bi bi-check-circle-fill fs-2 text-info"></i></div>
                    <div class="display-6 fw-bold">{{ finishedCount }}</div>
                    <div class="text-muted mt-1" style="font-size:.8125rem;">Finished</div>
                </div>
            </div>
        </div>
    </div>

    {# Status breakdown — badges in a single row #}
    <div class="d-flex gap-3 mb-4">
        <span class="badge badge-status badge-scheduled px-3 py-2" style="font-size:.85rem;">
            Scheduled <span class="fw-bold ms-1">{{ scheduledCount }}</span>
        </span>
        <span class="badge badge-status badge-in_progress px-3 py-2" style="font-size:.85rem;">
            In Progress <span class="fw-bold ms-1">{{ inProgressCount }}</span>
        </span>
        <span class="badge badge-status badge-finished px-3 py-2" style="font-size:.85rem;">
            Finished <span class="fw-bold ms-1">{{ finishedCount }}</span>
        </span>
    </div>

    {# Latest matches #}
    <div class="card table-card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
            <h6 class="mb-0 fw-bold">Latest Matches</h6>
            <a href="{{ path('admin_match_index') }}" class="btn btn-sm btn-outline-primary">View All</a>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>League</th>
                        <th>Home</th>
                        <th class="text-center">Score</th>
                        <th>Away</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    {% for match in latestMatches %}
                        <tr>
                            <td class="text-muted">{{ match.startDate|date('d M Y, H:i') }}</td>
                            <td><span class="badge bg-primary bg-opacity-10 text-primary">{{ match.league.code }}</span></td>
                            <td class="fw-medium">{{ match.homeTeam.name }}</td>
                            <td class="text-center score-display">
                                {% if match.homeScore is not null %}
                                    {{ match.homeScore }} &ndash; {{ match.awayScore }}
                                {% else %}
                                    <span class="text-muted">&mdash;</span>
                                {% endif %}
                            </td>
                            <td class="fw-medium">{{ match.awayTeam.name }}</td>
                            <td><span class="badge badge-status badge-{{ match.status.value }}">{{ match.status.value|replace({'_': ' '})|capitalize }}</span></td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                No matches yet. <a href="{{ path('admin_import_index') }}">Import data</a> to get started.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# Quick actions #}
    <div class="mt-4">
        <a href="{{ path('admin_import_index') }}" class="btn btn-primary">
            <i class="bi bi-cloud-arrow-down me-1"></i> Import Data
        </a>
    </div>
{% endblock %}
