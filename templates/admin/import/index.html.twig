{% extends 'admin/base.html.twig' %}

{% block page_title %}Import Data{% endblock %}
{% block topbar_title %}Import{% endblock %}

{% block content %}
    <div class="mb-4">
        <h4 class="fw-bold mb-1">Import Football Data</h4>
        <p class="text-muted mb-0" style="font-size:.875rem;">Import leagues, teams and match data from football-data.org API.</p>
    </div>

    <div class="card shadow-sm border-0 mb-4" style="border-radius:.75rem;">
        <div class="card-body">
            <form method="post" action="{{ path('admin_import_run') }}" data-controller="import">
                <h6 class="fw-bold mb-3">Select Competitions</h6>
                {% for code, name in competitions %}
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" name="competitions[]" value="{{ code }}" id="comp_{{ code }}" checked>
                        <label class="form-check-label" for="comp_{{ code }}">
                            <span class="badge bg-primary bg-opacity-10 text-primary me-1">{{ code }}</span> {{ name }}
                        </label>
                    </div>
                {% endfor %}

                <hr class="my-3">

                <button type="submit" class="btn btn-primary" data-import-target="button" data-action="import#submit">
                    <i class="bi bi-cloud-arrow-down me-1"></i>
                    <span data-import-target="label">Run Import</span>
                    <span data-import-target="spinner" class="d-none">
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        Importing...
                    </span>
                </button>
            </form>
        </div>
    </div>

    <div class="card table-card shadow-sm">
        <div class="card-header bg-white py-3">
            <h6 class="mb-0 fw-bold">Available Competitions</h6>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Competition</th>
                        <th>Country</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td><span class="badge bg-primary bg-opacity-10 text-primary">PL</span></td><td>Premier League</td><td>England</td></tr>
                    <tr><td><span class="badge bg-primary bg-opacity-10 text-primary">BL1</span></td><td>Bundesliga</td><td>Germany</td></tr>
                    <tr><td><span class="badge bg-primary bg-opacity-10 text-primary">PD</span></td><td>La Liga</td><td>Spain</td></tr>
                    <tr><td><span class="badge bg-primary bg-opacity-10 text-primary">SA</span></td><td>Serie A</td><td>Italy</td></tr>
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
