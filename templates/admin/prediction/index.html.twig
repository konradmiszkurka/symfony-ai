{% extends 'admin/base.html.twig' %}

{% block page_title %}Predictions{% endblock %}
{% block topbar_title %}Predictions{% endblock %}

{% block content %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">Match Predictions</h4>
            <small class="text-muted">{{ predictions|length }} predictions</small>
        </div>
        <form method="post" action="{{ path('admin_prediction_generate_all') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('generate_all') }}">
            <button type="submit" class="btn btn-primary btn-sm">
                <i class="bi bi-lightning-fill me-1"></i>Generate All Predictions
            </button>
        </form>
    </div>

    {# League filter #}
    <div class="card shadow-sm border-0 mb-4" style="border-radius:.75rem;">
        <div class="card-body">
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <span class="text-muted fw-medium" style="font-size:.8125rem;">Filter by league:</span>
                <a href="{{ path('admin_prediction_index') }}"
                   class="btn btn-sm {{ selectedLeagueCode is empty ? 'btn-primary' : 'btn-outline-secondary' }}">
                    All
                </a>
                {% for league in leagues %}
                    <a href="{{ path('admin_prediction_index', {league_code: league.code}) }}"
                       class="btn btn-sm {{ selectedLeagueCode == league.code ? 'btn-primary' : 'btn-outline-secondary' }}">
                        {{ league.code }}
                    </a>
                {% endfor %}
            </div>
        </div>
    </div>

    {# League generate buttons #}
    {% if leagues|length > 0 %}
        <div class="d-flex gap-2 flex-wrap mb-4">
            {% for league in leagues %}
                <form method="post" action="{{ path('admin_prediction_generate_league', {leagueId: league.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('generate_league_' ~ league.id) }}">
                    <button type="submit" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-arrow-repeat me-1"></i>Generate {{ league.code }}
                    </button>
                </form>
            {% endfor %}
        </div>
    {% endif %}

    {# Predictions table #}
    <div class="card table-card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>League</th>
                        <th>Home</th>
                        <th>Away</th>
                        <th class="text-center">1 (%)</th>
                        <th class="text-center">X (%)</th>
                        <th class="text-center">2 (%)</th>
                        <th class="text-center">Odds 1/X/2</th>
                        <th class="text-center">Most Likely</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for prediction in predictions %}
                        {% set maxProb = max(prediction.homeWinProbability, prediction.drawProbability, prediction.awayWinProbability) %}
                        <tr>
                            <td class="text-muted">{{ prediction.matchStartDate|date('d M Y, H:i') }}</td>
                            <td><span class="badge bg-primary bg-opacity-10 text-primary">{{ prediction.leagueCode }}</span></td>
                            <td class="fw-medium">{{ prediction.homeTeamName }}</td>
                            <td class="fw-medium">{{ prediction.awayTeamName }}</td>
                            <td class="text-center {% if prediction.homeWinProbability == maxProb %}fw-bold text-success{% endif %}">
                                {{ prediction.homeWinProbability|number_format(1) }}%
                            </td>
                            <td class="text-center {% if prediction.drawProbability == maxProb %}fw-bold text-success{% endif %}">
                                {{ prediction.drawProbability|number_format(1) }}%
                            </td>
                            <td class="text-center {% if prediction.awayWinProbability == maxProb %}fw-bold text-success{% endif %}">
                                {{ prediction.awayWinProbability|number_format(1) }}%
                            </td>
                            <td class="text-center text-muted" style="font-size:.8125rem;">
                                {{ prediction.homeOdds|number_format(2) }} /
                                {{ prediction.drawOdds|number_format(2) }} /
                                {{ prediction.awayOdds|number_format(2) }}
                            </td>
                            <td class="text-center">
                                <span class="badge bg-secondary">{{ prediction.mostLikelyScore }}</span>
                            </td>
                            <td class="text-end">
                                <a href="{{ path('admin_prediction_show', {matchId: prediction.matchId}) }}"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="10" class="text-center text-muted py-5">
                                No predictions found. Click "Generate All Predictions" to start.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
