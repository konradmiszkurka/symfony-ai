{% extends 'admin/base.html.twig' %}

{% block page_title %}Teams{% endblock %}
{% block topbar_title %}Teams{% endblock %}

{% block content %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">All Teams</h4>
            <small class="text-muted">{{ teams|length }} teams imported</small>
        </div>
    </div>

    <div class="card table-card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped">
                <thead>
                    <tr>
                        <th style="width:40px;"></th>
                        <th>Name</th>
                        <th>Short Name</th>
                        <th>TLA</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for team in teams %}
                        <tr>
                            <td>
                                {% if team.crest %}
                                    <img src="{{ team.crest }}" alt="" style="width:30px;height:30px;" loading="lazy">
                                {% endif %}
                            </td>
                            <td class="fw-medium">{{ team.name }}</td>
                            <td class="text-muted">{{ team.shortName ?? '-' }}</td>
                            <td><span class="badge bg-secondary bg-opacity-10 text-secondary">{{ team.tla ?? '-' }}</span></td>
                            <td class="text-end">
                                <a href="{{ path('admin_team_show', {id: team.id}) }}" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye me-1"></i>View
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">No teams imported yet.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
